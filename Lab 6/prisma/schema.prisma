generator client {
  provider = "prisma-client"
  output   = "../db-client"
}

datasource db {
  provider = "postgresql"
}

model categories {
  category_id   Int        @id @default(autoincrement())
  category_name String     @unique @db.VarChar(50)
  projects      projects[]
}

model companies {
  company_id   Int         @id @default(autoincrement())
  company_name String      @unique @db.VarChar(150)
  employers    employers[]
}

model developer_links {
  link_id    Int        @id @default(autoincrement())
  dev_id     Int
  link_url   String     @db.VarChar(255)
  developers developers @relation(fields: [dev_id], references: [dev_id], onDelete: Cascade, onUpdate: NoAction)
}

model developers {
  dev_id           Int               @id
  is_searching_job Boolean           @default(true)
  developer_links  developer_links[]
  users            users             @relation(fields: [dev_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  projects         projects[]
}

model employers {
  employer_id       Int        @id
  company_id        Int?
  employer_position String     @db.VarChar(100)
  companies         companies? @relation(fields: [company_id], references: [company_id], onUpdate: NoAction)
  users             users      @relation(fields: [employer_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model projects {
  project_id          Int         @id @default(autoincrement())
  dev_id              Int
  category_id         Int?
  project_name        String      @db.VarChar(150)
  project_description String
  project_url         String      @db.VarChar(255)
  project_active      Boolean     @default(true)
  categories          categories? @relation(fields: [category_id], references: [category_id], onUpdate: NoAction)
  developers          developers  @relation(fields: [dev_id], references: [dev_id], onDelete: Cascade, onUpdate: NoAction)
  reviews     reviews[]
}

model users {
  user_id      Int       @id @default(autoincrement())
  user_name    String    @db.VarChar(30)
  user_surname String    @db.VarChar(50)
  user_country String    @db.VarChar(100)
  user_email   String    @unique @db.VarChar(100)
  balance      Float     @default(0.0)

  developers   developers?
  employers    employers?
}

model reviews {
  review_id   Int      @id @default(autoincrement())
  rating      Int
  comment     String?
  project_id  Int
  projects    projects @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
}
